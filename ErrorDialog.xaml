<Window x:Class="AudioQualityChecker.ErrorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        Height="200" Width="420"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#FF1A1010" BorderBrush="#FFAA2222" BorderThickness="1.5" CornerRadius="8">
        <Grid Margin="20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" MouseLeftButtonDown="Header_MouseDown">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                               Foreground="#FFFF4444" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock x:Name="TitleText" Text="Error" FontSize="16" FontWeight="Bold"
                               FontFamily="Segoe UI" Foreground="#FFFF6666" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Message -->
            <ScrollViewer Grid.Row="1" Margin="0,12,0,12" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <TextBlock x:Name="MessageText" TextWrapping="Wrap"
                           FontSize="13" FontFamily="Segoe UI"
                           Foreground="#FFCCAAAA" LineHeight="20"/>
            </ScrollViewer>

            <!-- OK Button -->
            <Button Grid.Row="2" Content="OK" Width="90" HorizontalAlignment="Right"
                    Click="OK_Click" Padding="12,6" Cursor="Hand"
                    FontFamily="Segoe UI" FontSize="13">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#FF3A2020" BorderBrush="#FF882222"
                                BorderThickness="1" CornerRadius="3" Padding="12,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF552222"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#FFCC3333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <Button.Foreground>
                    <SolidColorBrush Color="#FFDDAAAA"/>
                </Button.Foreground>
            </Button>
        </Grid>
    </Border>
</Window>
