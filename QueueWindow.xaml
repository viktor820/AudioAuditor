<Window x:Class="AudioQualityChecker.QueueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        Height="520" Width="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBg}"
        Foreground="{DynamicResource TextPrimary}"
        AllowsTransparency="True">

    <Border Background="{DynamicResource PanelBg}"
            BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" MouseLeftButtonDown="Header_MouseDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE90B;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="{DynamicResource AccentColor}" Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Play Queue"
                               FontSize="18" FontWeight="Bold" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock x:Name="QueueCount" Text="  (0 songs)"
                               FontSize="13" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextMuted}"
                               VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                </StackPanel>
                <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Click="Close_Click" Cursor="Hand"
                        Background="Transparent" BorderBrush="Transparent"
                        Foreground="{DynamicResource TextMuted}" Padding="6,4">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" CornerRadius="3" Padding="6,4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#44FF4444"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Queue ListBox -->
            <Border Grid.Row="2" Background="{DynamicResource GridBg}"
                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="3">
                <ListBox x:Name="QueueList"
                         Background="Transparent"
                         Foreground="{DynamicResource TextPrimary}"
                         BorderThickness="0"
                         FontFamily="Segoe UI" FontSize="12"
                         SelectionChanged="QueueList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE8D6;"
                                           FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           Foreground="{DynamicResource TextMuted}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimary}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Artist}" FontSize="11"
                                               Foreground="{DynamicResource TextMuted}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding Duration}"
                                           Foreground="{DynamicResource TextMuted}" FontSize="11"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            <Setter Property="Padding" Value="4,2"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}" CornerRadius="3">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="bd" Property="Background"
                                                        Value="{DynamicResource SelectionBg}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background"
                                                        Value="{DynamicResource RowHoverBg}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Border>

            <!-- Action buttons -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Click="MoveUp_Click" ToolTip="Move Up" Margin="0,0,3,0"
                        Background="{DynamicResource ButtonBg}" Foreground="{DynamicResource TextPrimary}"
                        BorderBrush="{DynamicResource ButtonBorder}" Cursor="Hand" Padding="4,5">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                    CornerRadius="3" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE74A;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="Up" FontFamily="Segoe UI" FontSize="12"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonHover}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="1" Click="MoveDown_Click" ToolTip="Move Down" Margin="3,0,3,0"
                        Background="{DynamicResource ButtonBg}" Foreground="{DynamicResource TextPrimary}"
                        BorderBrush="{DynamicResource ButtonBorder}" Cursor="Hand" Padding="4,5">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                    CornerRadius="3" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE74B;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="Down" FontFamily="Segoe UI" FontSize="12"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonHover}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="2" Click="Remove_Click" ToolTip="Remove Selected" Margin="3,0,3,0"
                        Background="{DynamicResource ButtonBg}" Foreground="{DynamicResource TextPrimary}"
                        BorderBrush="{DynamicResource ButtonBorder}" Cursor="Hand" Padding="4,5">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                    CornerRadius="3" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="Remove" FontFamily="Segoe UI" FontSize="12"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#44FF4444"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="3" Click="ClearQueue_Click" ToolTip="Clear All" Margin="3,0,0,0"
                        Background="{DynamicResource ButtonBg}" Foreground="{DynamicResource TextPrimary}"
                        BorderBrush="{DynamicResource ButtonBorder}" Cursor="Hand" Padding="4,5">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                    CornerRadius="3" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="Clear" FontFamily="Segoe UI" FontSize="12"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#44FF4444"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Close button -->
            <Button Grid.Row="6" Content="Done" Width="90" HorizontalAlignment="Right"
                    Click="Close_Click" Padding="12,6"
                    Background="{DynamicResource ButtonBg}"
                    Foreground="{DynamicResource TextPrimary}"
                    BorderBrush="{DynamicResource ButtonBorder}"
                    FontFamily="Segoe UI" FontSize="13" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource ButtonHover}"/>
                                <Setter TargetName="bd" Property="BorderBrush"
                                        Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</Window>
