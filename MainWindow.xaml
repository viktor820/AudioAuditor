<Window x:Class="AudioQualityChecker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:AudioQualityChecker.Converters"
        Title="AudioAuditor"
        Height="700" Width="1250"
        MinHeight="550" MinWidth="1000"
        Background="{DynamicResource WindowBg}"
        Foreground="{DynamicResource TextPrimary}"
        WindowStartupLocation="CenterScreen"
        Icon="icon.png"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">

    <Window.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColor"/>
        <converters:StatusToTextConverter x:Key="StatusToText"/>
        <converters:ClippingToColorConverter x:Key="ClippingToColor"/>
        <converters:BitrateToColorConverter x:Key="BitrateToColor"/>
        <converters:MqaToColorConverter x:Key="MqaToColor"/>
        <converters:AiToColorConverter x:Key="AiToColor"/>

        <!-- ═══ Scrollbar Styles ═══ -->
        <Style x:Key="ScrollBarThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="thumbBorder"
                                Background="{DynamicResource ScrollThumb}"
                                CornerRadius="4" Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="thumbBorder" Property="Background"
                                        Value="{DynamicResource ScrollThumbHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarPageButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{DynamicResource ScrollBg}"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="{DynamicResource ScrollBg}" CornerRadius="4"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarPageButton}"
                                                  Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarPageButton}"
                                                  Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="12"/>
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid>
                                    <Border Background="{DynamicResource ScrollBg}" CornerRadius="4"/>
                                    <Track x:Name="PART_Track" IsDirectionReversed="False">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageButton}"
                                                          Command="ScrollBar.PageLeftCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageButton}"
                                                          Command="ScrollBar.PageRightCommand"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Dark button style -->
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource ButtonHover}"/>
                                <Setter TargetName="bd" Property="BorderBrush"
                                        Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource ButtonPressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Player button -->
        <Style x:Key="PlayerButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- Volume slider with circle thumb matching seek bar -->
        <Style x:Key="VolumeSlider" TargetType="Slider">
            <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Background" Value="{DynamicResource ScrollBg}"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="3" VerticalAlignment="Center"
                                    Background="{DynamicResource ScrollBg}" CornerRadius="1.5"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" IsTabStop="False"
                                                  Focusable="False" OverridesDefaultStyle="True">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" VerticalAlignment="Center"
                                                        Background="{DynamicResource AccentColor}"
                                                        CornerRadius="1.5"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" IsTabStop="False"
                                                  Focusable="False" OverridesDefaultStyle="True">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb OverridesDefaultStyle="True" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="volThumb" Width="12" Height="12"
                                                         Fill="{DynamicResource AccentColor}"
                                                         Stroke="{DynamicResource TextPrimary}"
                                                         StrokeThickness="1.2">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect ShadowDepth="0" BlurRadius="3"
                                                                          Opacity="0.25" Color="Black"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="volThumb" Property="Width" Value="14"/>
                                                        <Setter TargetName="volThumb" Property="Height" Value="14"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Seek slider with circle thumb and click-to-position -->
        <Style x:Key="SeekSlider" TargetType="Slider">
            <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Background" Value="{DynamicResource ScrollBg}"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="4" VerticalAlignment="Center"
                                    Background="{DynamicResource ScrollBg}" CornerRadius="2"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" IsTabStop="False"
                                                  Focusable="False" OverridesDefaultStyle="True">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" VerticalAlignment="Center"
                                                        Background="{DynamicResource AccentColor}"
                                                        CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" IsTabStop="False"
                                                  Focusable="False" OverridesDefaultStyle="True">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb OverridesDefaultStyle="True" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="thumbCircle" Width="14" Height="14"
                                                         Fill="{DynamicResource AccentColor}"
                                                         Stroke="{DynamicResource TextPrimary}"
                                                         StrokeThickness="1.5">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect ShadowDepth="0" BlurRadius="4"
                                                                          Opacity="0.3" Color="Black"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="thumbCircle" Property="Width" Value="16"/>
                                                        <Setter TargetName="thumbCircle" Property="Height" Value="16"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed ComboBox style -->
        <Style x:Key="ThemedComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="toggleBorder"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="3" Padding="6,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="16"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"/>
                                                <TextBlock Grid.Column="1" Text="&#xE70D;"
                                                           FontFamily="Segoe MDL2 Assets" FontSize="9"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="toggleBorder" Property="Background"
                                                        Value="{DynamicResource ButtonHover}"/>
                                                <Setter TargetName="toggleBorder" Property="BorderBrush"
                                                        Value="{DynamicResource AccentColor}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              HorizontalAlignment="Left" VerticalAlignment="Center"
                                              Margin="8,4,24,4" IsHitTestVisible="False"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="300">
                                    <Border x:Name="DropDownBorder"
                                            Background="{DynamicResource PanelBg}"
                                            BorderBrush="{DynamicResource ButtonBorder}"
                                            BorderThickness="1" CornerRadius="3"
                                            Margin="0,1,0,0" Padding="2">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemedComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="3" Margin="1">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource RowHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource SelectionBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search box style -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ═══ Themed Context Menu ═══ -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource PanelBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="HasDropShadow" Value="False"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="2"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True">
                            <StackPanel IsItemsHost="True"
                                        SnapsToDevicePixels="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="3"
                                Margin="0" SnapsToDevicePixels="True">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource RowHoverBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background" Value="{DynamicResource ButtonBorder}"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="4,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Background="{TemplateBinding Background}"
                                Height="{TemplateBinding Height}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- ═══ Toolbar ═══ -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource ToolbarBg}" Padding="8,6"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Click="AddFiles_Click" Style="{StaticResource DarkButton}" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Add Files" FontFamily="Segoe UI" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="AddFolder_Click" Style="{StaticResource DarkButton}" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Add Folder" FontFamily="Segoe UI" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Rectangle Width="1" Fill="{DynamicResource ButtonBorder}" Margin="4,2"/>
                    <Button Click="ClearAll_Click" FontSize="12"
                            Style="{StaticResource DarkButton}" Margin="4,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Clear All" FontFamily="Segoe UI" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Rectangle Width="1" Fill="{DynamicResource ButtonBorder}" Margin="2,2"/>
                    <Button x:Name="ExportDropdownBtn" Click="ExportDropdown_Click"
                            Style="{StaticResource DarkButton}" Margin="4,0,4,0">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Export Results" Click="ExportResults_Click"/>
                                <MenuItem Header="Save Spectrograms" Click="SaveAllSpectrograms_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Export" FontFamily="Segoe UI" FontSize="12"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="8"
                                       VerticalAlignment="Center" Margin="5,1,0,0"/>
                        </StackPanel>
                    </Button>
                    <Rectangle Width="1" Fill="{DynamicResource ButtonBorder}" Margin="2,2"/>
                    <Button Click="Queue_Click" Style="{StaticResource DarkButton}" Margin="4,0,4,0"
                            ToolTip="Play Queue">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE90B;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Queue" FontFamily="Segoe UI" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Rectangle Width="1" Fill="{DynamicResource ButtonBorder}" Margin="2,2"/>
                    <Button Click="Settings_Click" Style="{StaticResource DarkButton}" Margin="4,0,0,0"
                            ToolTip="Settings">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Settings" FontFamily="Segoe UI" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Music Service Search Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                            Margin="12,0">
                    <Button x:Name="ServiceBtn1" Click="ServiceSearch_Click" Tag="0"
                            Style="{StaticResource DarkButton}" Margin="3,0,3,0" Padding="3"
                            MinWidth="0" ToolTip="Search on Spotify">
                        <Image x:Name="ServiceImage1" Width="28" Height="28" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>
                    <Button x:Name="ServiceBtn2" Click="ServiceSearch_Click" Tag="1"
                            Style="{StaticResource DarkButton}" Margin="0,0,3,0" Padding="3"
                            MinWidth="0" ToolTip="Search on YouTube Music">
                        <Image x:Name="ServiceImage2" Width="28" Height="28" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>
                    <Button x:Name="ServiceBtn3" Click="ServiceSearch_Click" Tag="2"
                            Style="{StaticResource DarkButton}" Margin="0,0,3,0" Padding="3"
                            MinWidth="0" ToolTip="Search on Tidal">
                        <Image x:Name="ServiceImage3" Width="28" Height="28" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>
                    <Button x:Name="ServiceBtn4" Click="ServiceSearch_Click" Tag="3"
                            Style="{StaticResource DarkButton}" Margin="0,0,3,0" Padding="3"
                            MinWidth="0" ToolTip="Search on Qobuz">
                        <Image x:Name="ServiceImage4" Width="28" Height="28" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>
                    <Button x:Name="ServiceBtn5" Click="ServiceSearch_Click" Tag="4"
                            Style="{StaticResource DarkButton}" Margin="0,0,3,0" Padding="3"
                            MinWidth="0" ToolTip="Search on Amazon Music">
                        <Image x:Name="ServiceImage5" Width="28" Height="28" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>
                    <Button x:Name="ServiceBtn6" Click="ServiceSearch_Click" Tag="5"
                            Style="{StaticResource DarkButton}" Margin="0,0,3,0" Padding="3"
                            MinWidth="0" ToolTip="Search on Apple Music">
                        <Image x:Name="ServiceImage6" Width="28" Height="28" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>
                </StackPanel>

                <!-- Status Filter + Search bar -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <ComboBox x:Name="StatusFilterCombo" Width="115" Margin="0,0,6,0"
                              SelectionChanged="StatusFilterCombo_SelectionChanged"
                              ToolTip="Filter by status"
                              Style="{StaticResource ThemedComboBox}"
                              VerticalContentAlignment="Center">
                        <ComboBoxItem Content="All Statuses" IsSelected="True"/>
                        <ComboBoxItem Content="Real"/>
                        <ComboBoxItem Content="Fake"/>
                        <ComboBoxItem Content="Unknown"/>
                        <ComboBoxItem Content="Corrupted"/>
                        <ComboBoxItem Content="Optimized"/>
                        <ComboBoxItem Content="Mismatched BR"/>
                    </ComboBox>
                    <Grid Width="240">
                        <TextBox x:Name="SearchBox" Style="{StaticResource SearchBox}"
                                 TextChanged="SearchBox_TextChanged"
                                 ToolTip="Search by filename, artist, title, path, extension..."
                                 Padding="26,4,6,4"/>
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"
                                   HorizontalAlignment="Left" Margin="7,0,0,0"
                                   IsHitTestVisible="False"/>
                        <TextBlock x:Name="SearchPlaceholder" Text="Search... or Ctrl+F"
                                   FontFamily="Segoe UI" FontSize="13"
                                   Foreground="{DynamicResource TextDim}" VerticalAlignment="Center"
                                   HorizontalAlignment="Left" Margin="28,0,0,0"
                                   IsHitTestVisible="False"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Status Bar ═══ -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource ToolbarBg}" Padding="10,5"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Text="Ready — Drag and drop audio files or folders to begin"
                           Foreground="{DynamicResource TextSecondary}" FontSize="12"
                           VerticalAlignment="Center" FontFamily="Segoe UI"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ProgressBar x:Name="AnalysisProgress"
                                 Width="200" Height="14"
                                 Visibility="Collapsed"
                                 Foreground="{DynamicResource AccentColor}"
                                 Background="{DynamicResource ProgressBg}"
                                 BorderBrush="{DynamicResource ButtonBorder}" Margin="0,0,10,0"/>
                </StackPanel>
                <TextBlock Grid.Column="2" x:Name="LastFmStatusIndicator"
                           Text="Last.fm: Not Connected"
                           Foreground="{DynamicResource TextMuted}" FontSize="11"
                           FontFamily="Segoe UI" VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           Cursor="Hand" MouseLeftButtonDown="LastFmStatus_Click">
                    <TextBlock.ToolTip>
                        <ToolTip Content="Click to open your Last.fm profile"/>
                    </TextBlock.ToolTip>
                </TextBlock>
            </Grid>
        </Border>

        <!-- ═══ Main Content ═══ -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="3*" MinHeight="200"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="200"/>
            </Grid.RowDefinitions>

            <!-- ═══ DataGrid ═══ -->
            <DataGrid Grid.Row="0"
                      x:Name="FileGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionChanged="FileGrid_SelectionChanged"
                      MouseDoubleClick="FileGrid_MouseDoubleClick"
                      PreviewMouseWheel="FileGrid_PreviewMouseWheel"
                      Background="{DynamicResource GridBg}"
                      Foreground="{DynamicResource TextPrimary}"
                      RowBackground="{DynamicResource GridRowBg}"
                      AlternatingRowBackground="{DynamicResource GridAltRowBg}"
                      BorderBrush="{DynamicResource BorderColor}"
                      BorderThickness="0"
                      GridLinesVisibility="All"
                      HorizontalGridLinesBrush="{DynamicResource GridLineColor}"
                      VerticalGridLinesBrush="{DynamicResource GridLineColor}"
                      HeadersVisibility="Column"
                      CanUserSortColumns="True"
                      CanUserReorderColumns="True"
                      CanUserResizeColumns="True"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      SelectionUnit="FullRow"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True">

                <!-- Column Header Style -->
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource HeaderBg}"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                        <Setter Property="Padding" Value="8,7"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <!-- Row Style -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SelectionBg}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource RowHoverBg}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <!-- Cell Style -->
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="{TemplateBinding Background}" Padding="5,3">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <!-- Context Menu -->
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Play" Click="PlayFile_Click"/>
                        <MenuItem Header="Add to Queue" Click="AddToQueue_Click"/>
                        <Separator/>
                        <MenuItem Header="Save Spectrogram..." Click="SaveSpectrogram_Click"/>
                        <MenuItem Header="View Album Cover" Click="ViewAlbumCover_Click"/>
                        <Separator/>
                        <MenuItem Header="Open File Location" Click="OpenFileLocation_Click"/>
                        <MenuItem Header="Copy Path" Click="CopyPath_Click"/>
                        <MenuItem Header="Copy File Name" Click="CopyFileName_Click"/>
                        <Separator/>
                        <MenuItem Header="Remove from List" Click="RemoveFromList_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>

                <!-- ═══ Columns ═══ -->
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Status" Width="100" SortMemberPath="Status">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Status, Converter={StaticResource StatusToColor}}"
                                        CornerRadius="3" Padding="8,2" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Status, Converter={StaticResource StatusToText}}"
                                               Foreground="White" FontWeight="Bold" FontSize="11"
                                               FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="180"/>
                    <DataGridTextColumn Header="Artist" Binding="{Binding Artist}" Width="140"/>
                    <DataGridTextColumn Header="Filename" Binding="{Binding FileName}" Width="180"/>
                    <DataGridTextColumn Header="Path" Binding="{Binding FilePath}" Width="140"/>
                    <DataGridTextColumn Header="Sample Rate" Binding="{Binding SampleRateDisplay}" Width="105"/>
                    <DataGridTextColumn Header="Bits" Binding="{Binding BitsPerSampleDisplay}" Width="65"/>
                    <DataGridTextColumn Header="Ch" Binding="{Binding ChannelsDisplay}" Width="60"/>
                    <DataGridTextColumn Header="Duration" Binding="{Binding Duration}" Width="75"/>
                    <DataGridTextColumn Header="Size" Binding="{Binding FileSize}" Width="80"/>

                    <!-- Bitrate (color-coded) -->
                    <DataGridTemplateColumn Header="Bitrate" Width="95" SortMemberPath="ReportedBitrate">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ReportedBitrateDisplay}"
                                           FontSize="12" FontFamily="Segoe UI"
                                           FontWeight="SemiBold">
                                    <TextBlock.Foreground>
                                        <MultiBinding Converter="{StaticResource BitrateToColor}">
                                            <Binding Path="ReportedBitrate"/>
                                            <Binding Path="ActualBitrate"/>
                                        </MultiBinding>
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Actual Bitrate (color-coded) -->
                    <DataGridTemplateColumn Header="Actual BR" Width="95" SortMemberPath="ActualBitrate">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ActualBitrateDisplay}"
                                           FontSize="12" FontFamily="Segoe UI"
                                           FontWeight="SemiBold">
                                    <TextBlock.Foreground>
                                        <MultiBinding Converter="{StaticResource BitrateToColor}">
                                            <Binding Path="ReportedBitrate"/>
                                            <Binding Path="ActualBitrate"/>
                                        </MultiBinding>
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Ext" Binding="{Binding Extension}" Width="60"/>
                    <DataGridTextColumn Header="Max Freq" Binding="{Binding EffectiveFrequencyDisplay}" Width="100"/>

                    <DataGridTemplateColumn Header="Clipping" Width="95" SortMemberPath="HasClipping">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ClippingDisplay}"
                                           Foreground="{Binding HasClipping, Converter={StaticResource ClippingToColor}}"
                                           FontWeight="SemiBold" FontSize="11" FontFamily="Segoe UI"
                                           HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="BPM" Binding="{Binding BpmDisplay}" Width="65"/>
                    <DataGridTextColumn Header="Replay Gain" Binding="{Binding ReplayGainDisplay}" Width="105"/>

                    <!-- MQA Detection -->
                    <DataGridTemplateColumn Header="MQA" Width="120" SortMemberPath="IsMqa">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding MqaDisplay}"
                                           Foreground="{Binding IsMqa, Converter={StaticResource MqaToColor}}"
                                           FontWeight="SemiBold" FontSize="11" FontFamily="Segoe UI"
                                           HorizontalAlignment="Center"
                                           ToolTip="{Binding MqaEncoder}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- AI Detection -->
                    <DataGridTemplateColumn Header="AI" Width="120" SortMemberPath="IsAiGenerated">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding AiDisplay}"
                                           Foreground="{Binding IsAiGenerated, Converter={StaticResource AiToColor}}"
                                           FontWeight="SemiBold" FontSize="11" FontFamily="Segoe UI"
                                           HorizontalAlignment="Center"
                                           ToolTip="{Binding AiSource}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- ═══ Grid Splitter ═══ -->
            <GridSplitter Grid.Row="1" Height="5"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource SplitterBg}"
                          ShowsPreview="True"/>

            <!-- ═══ Bottom Panel (Spectrogram + Player) ═══ -->
            <Border Grid.Row="2" Background="{DynamicResource PanelBg}"
                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0">
                <DockPanel>
                    <!-- ═══ Player Bar ═══ -->
                    <Border DockPanel.Dock="Bottom" Background="{DynamicResource GridAltRowBg}"
                            Padding="10,6" BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" x:Name="BtnShuffle"
                                    Click="Shuffle_Click" Style="{StaticResource PlayerButton}"
                                    ToolTip="Shuffle">
                                <TextBlock x:Name="ShuffleIcon" Text="&#xE8B1;"
                                           FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Foreground="{DynamicResource TextMuted}"/>
                            </Button>
                            <Button Grid.Column="1" x:Name="BtnPrevTrack"
                                    Click="PrevTrack_Click" Style="{StaticResource PlayerButton}" Margin="4,0,0,0"
                                    ToolTip="Previous Track">
                                <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                            </Button>
                            <Button Grid.Column="2" Click="Rewind_Click"
                                    Style="{StaticResource PlayerButton}" Margin="4,0,0,0"
                                    ToolTip="Rewind 5s">
                                <TextBlock Text="&#xEB9E;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                            </Button>
                            <Button Grid.Column="3" x:Name="BtnPlayPause"
                                    Click="PlayPause_Click" Style="{StaticResource PlayerButton}" Margin="4,0,0,0">
                                <TextBlock x:Name="PlayPauseIcon" Text="&#xE768;"
                                           FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                            </Button>
                            <Button Grid.Column="4" Click="Forward_Click"
                                    Style="{StaticResource PlayerButton}" Margin="4,0,0,0"
                                    ToolTip="Forward 5s">
                                <TextBlock Text="&#xEB9D;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                            </Button>
                            <Button Grid.Column="5" x:Name="BtnNextTrack"
                                    Click="NextTrack_Click" Style="{StaticResource PlayerButton}" Margin="4,0,0,0"
                                    ToolTip="Next Track">
                                <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                            </Button>

                            <!-- Seek bar + waveform + time -->
                            <Grid Grid.Column="6" Margin="12,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Canvas x:Name="WaveformCanvas" Height="26" ClipToBounds="True"
                                            VerticalAlignment="Center" Margin="0"/>
                                    <Slider x:Name="SeekSlider"
                                            Minimum="0" Maximum="100" Value="0"
                                            ValueChanged="SeekSlider_ValueChanged"
                                            PreviewMouseLeftButtonDown="SeekSlider_PreviewMouseDown"
                                            PreviewMouseLeftButtonUp="SeekSlider_MouseUp"
                                            Thumb.DragCompleted="SeekSlider_DragCompleted"
                                            Style="{StaticResource SeekSlider}"
                                            VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Grid.Row="1">
                                    <TextBlock x:Name="PlayerTimeText" Text="0:00 / 0:00"
                                               Foreground="{DynamicResource TextMuted}" FontSize="11"
                                               FontFamily="Segoe UI" HorizontalAlignment="Left"/>
                                    <TextBlock x:Name="PlayerFileText" Text=""
                                               Visibility="Collapsed"/>
                                </Grid>
                            </Grid>

                            <!-- Volume -->
                            <TextBlock Grid.Column="7" x:Name="VolumeIcon" Text="&#xE767;"
                                       FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"
                                       Margin="0,0,4,0" Cursor="Hand"
                                       MouseLeftButtonDown="VolumeIcon_Click"/>
                            <TextBlock Grid.Column="8" x:Name="VolumeLabel" Text="100%"
                                       Foreground="{DynamicResource TextMuted}" FontSize="11"
                                       FontFamily="Segoe UI"
                                       VerticalAlignment="Center" Margin="0,0,6,0" Width="32"
                                       Cursor="Hand"
                                       MouseLeftButtonDown="VolumeIcon_Click"/>
                            <Slider Grid.Column="9" x:Name="VolumeSlider"
                                    Minimum="0" Maximum="100" Value="100"
                                    ValueChanged="VolumeSlider_ValueChanged"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource VolumeSlider}"/>

                            <!-- EQ Toggle -->
                            <Button Grid.Column="10" x:Name="BtnEqToggle" Click="EqToggle_Click"
                                    Style="{StaticResource PlayerButton}" Margin="8,0,0,0"
                                    ToolTip="Equalizer" Padding="6,4">
                                <TextBlock Text="EQ" FontFamily="Segoe UI" FontSize="11"
                                           FontWeight="Bold"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- ═══ Equalizer Panel ═══ -->
                    <Border x:Name="EqPanel" DockPanel.Dock="Bottom" Visibility="Collapsed"
                            Background="{DynamicResource GridAltRowBg}"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="0,1,0,0" Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                <CheckBox x:Name="ChkEqEnabled" Content="Enable"
                                          Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                          FontFamily="Segoe UI"
                                          Checked="EqEnabled_Changed" Unchecked="EqEnabled_Changed">
                                    <CheckBox.Template>
                                        <ControlTemplate TargetType="CheckBox">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border x:Name="checkBorder" Width="16" Height="16"
                                                        Background="{DynamicResource InputBg}"
                                                        BorderBrush="{DynamicResource ButtonBorder}"
                                                        BorderThickness="1" CornerRadius="3"
                                                        VerticalAlignment="Center" Margin="0,0,6,0">
                                                    <TextBlock x:Name="checkMark" Text="&#xE73E;"
                                                               FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                               Foreground="{DynamicResource AccentColor}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Visibility="Collapsed"/>
                                                </Border>
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                                    <Setter TargetName="checkBorder" Property="BorderBrush"
                                                            Value="{DynamicResource AccentColor}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="checkBorder" Property="BorderBrush"
                                                            Value="{DynamicResource AccentColor}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </CheckBox.Template>
                                </CheckBox>
                                <Button Content="Reset" FontSize="10" FontFamily="Segoe UI"
                                        Padding="8,3" Margin="0,6,0,0" Cursor="Hand"
                                        Click="EqReset_Click"
                                        Background="{DynamicResource ButtonBg}"
                                        Foreground="{DynamicResource TextMuted}"
                                        BorderBrush="{DynamicResource ButtonBorder}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="1" CornerRadius="3"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background"
                                                            Value="{DynamicResource ButtonHover}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>

                            <StackPanel Grid.Column="1" x:Name="EqSlidersPanel"
                                        Orientation="Horizontal" HorizontalAlignment="Center">
                                <!-- 10 EQ band sliders generated in code-behind -->
                            </StackPanel>

                            <TextBlock Grid.Column="2" Text="dB" FontSize="10" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextDim}" VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <!-- ═══ Spectrogram Area ═══ -->
                    <Grid>
                        <TextBlock x:Name="SpectrogramPlaceholder"
                                   Text="Select a file to view its spectrogram — Double-click or press Enter to play"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextDim}" FontSize="14" FontStyle="Italic"
                                   FontFamily="Segoe UI"/>

                        <StackPanel x:Name="SpectrogramLoading" Visibility="Collapsed"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Generating spectrogram..."
                                       Foreground="{DynamicResource TextMuted}" FontSize="14"
                                       FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                            <ProgressBar IsIndeterminate="True" Width="250" Height="4"
                                         Margin="0,10,0,0"
                                         Foreground="{DynamicResource AccentColor}"
                                         Background="{DynamicResource ProgressBg}"/>
                        </StackPanel>

                        <DockPanel x:Name="SpectrogramPanel" Visibility="Collapsed">
                            <Grid DockPanel.Dock="Top" Margin="10,5,10,6">
                                <TextBlock x:Name="SpectrogramTitle"
                                           Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                           FontWeight="SemiBold" FontFamily="Segoe UI"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="BtnToggleAlbumCover" Click="ToggleAlbumCover_Click"
                                            Cursor="Hand" Style="{StaticResource DarkButton}" Padding="6,2"
                                            ToolTip="Toggle Album Cover" Margin="0,0,6,0">
                                        <TextBlock x:Name="AlbumCoverToggleText" Text="♪ Cover"
                                                   FontSize="10" FontFamily="Segoe UI"/>
                                    </Button>
                                    <Button x:Name="BtnToggleVisualizer" Click="ToggleVisualizer_Click"
                                            HorizontalAlignment="Right" Cursor="Hand"
                                            Style="{StaticResource DarkButton}" Padding="6,2"
                                            ToolTip="Toggle Spectrogram / Visualizer">
                                        <TextBlock x:Name="VisualizerToggleText" Text="Visualizer"
                                                   FontSize="10" FontFamily="Segoe UI"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="5,0,5,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition x:Name="AlbumCoverColumn" Width="0"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <Grid x:Name="FreqLabelGrid" Width="40" HorizontalAlignment="Left"
                                          VerticalAlignment="Stretch" Margin="0,0,0,2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" x:Name="FreqLabelTop"
                                                   Foreground="{DynamicResource TextMuted}" FontSize="10"
                                                   FontFamily="Segoe UI" VerticalAlignment="Top"/>
                                        <TextBlock Grid.Row="1" x:Name="FreqLabelUpperMid"
                                                   Foreground="{DynamicResource TextMuted}" FontSize="10"
                                                   FontFamily="Segoe UI" VerticalAlignment="Top"/>
                                        <TextBlock Grid.Row="2" x:Name="FreqLabelMid"
                                                   Foreground="{DynamicResource TextMuted}" FontSize="10"
                                                   FontFamily="Segoe UI" VerticalAlignment="Top"/>
                                        <TextBlock Grid.Row="3" x:Name="FreqLabelLowerMid"
                                                   Foreground="{DynamicResource TextMuted}" FontSize="10"
                                                   FontFamily="Segoe UI" VerticalAlignment="Top"
                                                   Margin="0,-4,0,0"/>
                                        <TextBlock Grid.Row="3" x:Name="FreqLabelBot" Text="20 Hz"
                                                   Foreground="{DynamicResource TextMuted}" FontSize="10"
                                                   FontFamily="Segoe UI" VerticalAlignment="Bottom"/>
                                    </Grid>
                                    <Image x:Name="SpectrogramImage"
                                           Margin="43,0,0,2"
                                           Stretch="Fill"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           MouseLeftButtonDown="SpectrogramImage_MouseDoubleClick"/>
                                    <Canvas x:Name="VisualizerCanvas" Visibility="Collapsed"
                                            Margin="0,0,0,2" ClipToBounds="True"
                                            Background="Transparent"/>
                                </Grid>
                                <Border Grid.Column="1" x:Name="AlbumCoverPanel" Visibility="Collapsed"
                                        Margin="8,0,0,2" VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Background="Transparent">
                                    <Image x:Name="AlbumCoverImage"
                                           MaxWidth="200" MaxHeight="200"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           ToolTip="Album Cover"/>
                                </Border>
                            </Grid>
                        </DockPanel>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
